<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Recursos Operativos · Alonso & Espinosa</title>
  
  <link rel="icon" type="image/png" href="favicon.png">

  <meta name="description" content="Recursos, herramientas y artículos prácticos de Alonso & Espinosa para pymes. Plantillas Excel, guías operativas y sistemas gratuitos."/>
  <meta property="og:title" content="Biblioteca de Recursos · Alonso & Espinosa"/>
  <meta property="og:image" content="https://alauriela.github.io/alonsoespinosa-web/portada.png"/>

  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  
  <style>
    :root{
      --bg:#f4f7f9;
      --card:#ffffff;
      --text:#1a1a1a;
      --muted:#6b6b6b;
      --line:#dfe6e9;
      --accent:#2E4A5A;       /* Azul Oscuro Oficial */
      --accent2:#3E6B7B;      /* Azul Medio */
      --celeste:#5AD1E5;      /* Celeste Oficial */
      --accent-bg:#eef3fd;
      --sans:'DM Sans',system-ui,sans-serif;
      --serif:'Lora',Georgia,serif;
      --r:16px;
      --max:1060px;
      --shadow:0 10px 30px rgba(46, 74, 90, 0.08);
    }

    *{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:var(--sans);color:var(--text);background:var(--bg);line-height:1.6;font-size:16px}
    a{color:inherit;text-decoration:none}
    .wrap{max-width:var(--max);margin:0 auto;padding:0 20px}

    /* NAV */
    nav{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--line)}
    .nav-inner{display:flex;align-items:center;justify-content:space-between;max-width:var(--max);margin:0 auto;padding:0 20px;height:58px;gap:16px}
    .brand{display:flex;align-items:center;gap:8px;font-family:var(--serif);font-weight:600;font-size:16px;color:var(--accent)}
    .brand-dot{width:8px;height:8px;border-radius:50%;background:var(--celeste);flex-shrink:0}
    .nav-links{display:flex;gap:4px;align-items:center}
    .nav-links a{font-size:13px;color:var(--muted);padding:6px 9px;border-radius:8px;transition:.15s}
    .nav-links a:hover{color:var(--accent);background:var(--accent-bg)}

    /* HEADER */
    .page-header{padding:60px 0 40px}
    .page-title{font-family:var(--serif);font-size:clamp(30px,5vw,48px);font-weight:600;line-height:1.1;margin-bottom:16px;color:var(--accent)}
    .page-lead{font-size:17px;color:var(--muted);max-width:600px}

    /* ARTICLES GRID */
    .articles-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:40px}
    .article-card{background:var(--card);border:1px solid var(--line);border-radius:var(--r);overflow:hidden;box-shadow:var(--shadow);transition:.3s;display:flex;flex-direction:column;cursor:pointer}
    .article-card:hover{border-color:var(--celeste);transform:translateY(-4px)}
    
    .article-thumb{width:100%;aspect-ratio:16/9;background:#fff;border-bottom:1px solid var(--line);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
    
    /* MEJORA PORTADA: Aquí ajustamos para que no se vea mal */
    .article-thumb img{width:100%;height:100%;object-fit:contain;padding:10px;transition: .3s}
    .article-card:hover .article-thumb img{transform: scale(1.05)}

    .article-body{padding:20px;flex:1;display:flex;flex-direction:column}
    .article-sector{font-size:11px;font-weight:700;text-transform:uppercase;color:var(--accent);background:var(--accent-bg);padding:3px 10px;border-radius:999px;align-self: flex-start;margin-bottom:12px}
    .article-title{font-family:var(--serif);font-size:18px;font-weight:600;line-height:1.3;margin-bottom:8px;color:var(--accent)}
    .article-desc{font-size:13.5px;color:var(--muted);line-height:1.5;margin-bottom:16px}
    .article-link{font-size:14px;font-weight:600;color:var(--celeste)}

    /* GALLERY VIEWER */
    #gallery-viewer{display:none;margin-top:60px;padding-top:40px;border-top:2px solid var(--line);animation: fadeIn 0.5s ease;}
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    
    .gallery-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:32px}
    .gallery-grid{display:grid;grid-template-columns:1fr;gap:48px}
    .gallery-item{display:grid;grid-template-columns:260px 1fr;gap:32px;align-items:start}
    .gallery-item-num{width:32px;height:32px;border-radius:8px;background:var(--accent);color:white;display:flex;align-items:center;justify-content:center;font-weight:600;margin-bottom:12px}
    .gallery-item h4{font-family:var(--serif);font-size:20px;color:var(--accent);margin-bottom:8px}
    .gallery-img-container{border:1px solid var(--line);border-radius:var(--r);box-shadow:var(--shadow);overflow:hidden;background:#fff}
    .gallery-img-container img{width:100%;height:auto;display:block}

    .coming-soon{opacity:.6;filter:grayscale(0.8);pointer-events:none}

    .cta-strip{background:var(--accent);border-radius:var(--r);padding:40px;text-align:center;color:#fff;margin:60px 0}
    .btn-celeste{background:var(--celeste);color:var(--accent);padding:12px 24px;border-radius:999px;font-weight:700;display:inline-block;margin-top:20px}

    footer{border-top:1px solid var(--line);padding:40px 0;text-align:center;font-size:12px;color:var(--muted)}

    @media(max-width:900px){
      .articles-grid{grid-template-columns:1fr 1fr}
      .gallery-item{grid-template-columns:1fr}
    }
    @media(max-width:600px){.articles-grid{grid-template-columns:1fr}}
  </style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="index.html" class="brand"><span class="brand-dot"></span> Alonso & Espinosa</a>
    <div class="nav-links">
      <a href="index.html#verticales">Sectores</a>
      <a href="recursos.html" class="active">Recursos</a>
      <a href="https://alauriela.github.io/laboratorio-de-diagnostico-empresarial/" target="_blank">Laboratorio</a>
      <a href="index.html#contacto" class="nav-cta">Contacto</a>
    </div>
  </div>
</nav>

<div class="wrap">
  <div class="page-header">
    <div class="page-title">Herramientas para<br>ordenar tu operativa</div>
    <p class="page-lead">Sistemas y protocolos que implementamos en nuestros diagnósticos.</p>
  </div>

  <div class="articles-grid">
    <div class="article-card" onclick="toggleGallery()">
      <div class="article-thumb">
        <img src="portada.png" alt="Sistema Alérgenos">
      </div>
      <div class="article-body">
        <div class="article-sector">Hostelería</div>
        <div class="article-title">Sistema de Gestión de Alérgenos</div>
        <div class="article-desc">Automatiza tu matriz legal por palabras clave. Haz clic para ver cómo funciona.</div>
        <span class="article-link">Ver capturas del sistema →</span>
      </div>
    </div>

    <div class="article-card coming-soon">
        <div class="article-thumb"><span style="font-size:40px">📋</span></div>
        <div class="article-body"><div class="article-sector">Hostelería</div><div class="article-title">Checklist de Apertura</div></div>
    </div>
    <div class="article-card coming-soon">
        <div class="article-thumb"><span style="font-size:40px">🔧</span></div>
        <div class="article-body"><div class="article-sector">Instaladoras</div><div class="article-title">Control de Obra</div></div>
    </div>
  </div>

  <div id="gallery-viewer">
    <div class="gallery-header">
      <h2 style="font-family:var(--serif); color:var(--accent);">Funcionamiento del Sistema</h2>
      <button onclick="document.getElementById('gallery-viewer').style.display='none'" style="cursor:pointer; background:none; border:none; color:var(--muted)">Cerrar ✕</button>
    </div>
    
    <div class="gallery-grid">
      <div class="gallery-item">
        <div class="gallery-item-meta">
          <div class="gallery-item-num">1</div>
          <h4>Entrada de Ingredientes</h4>
          <p>Identificación automática de alérgenos por palabras clave.</p>
        </div>
        <div class="gallery-img-container"><img src="base-de-datos.png" alt="Base Datos"></div>
      </div>

      <div class="gallery-item">
        <div class="gallery-item-meta">
          <div class="gallery-item-num">2</div>
          <h4>Escandallo de Recetas</h4>
          <p>Cálculo dinámico de alérgenos para el plato final.</p>
        </div>
        <div class="gallery-img-container"><img src="escandallo-recetas.png" alt="Escandallo"></div>
      </div>

      <div class="gallery-item">
        <div class="gallery-item-meta">
          <div class="gallery-item-num">3</div>
          <h4>Matriz Final</h4>
          <p>Resultado profesional listo para inspección o QR.</p>
        </div>
        <div class="gallery-img-container"><img src="resumen-alergenos.png" alt="Resumen"></div>
      </div>
    </div>

    <div class="cta-strip">
      <h3>¿Quieres este sistema en tu negocio?</h3>
      <p>Te ayudamos a personalizarlo y formar a tu equipo.</p>
      <a href="index.html#contacto" class="btn-celeste">Hablemos ahora →</a>
    </div>
  </div>
</div>

<footer>
  <p>© 2026 Alonso & Espinosa · Responsabilidad · Autoría · Decisión</p>
</footer>

<script>
function toggleGallery() {
  const viewer = document.getElementById('gallery-viewer');
  viewer.style.display = 'block';
  setTimeout(() => { viewer.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 50);
}
</script>
</body>
</html>
